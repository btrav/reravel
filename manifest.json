{
  "manifest_version": 3,
  "name": "Reravel - Make distracting websites boring",
  "short_name": "Reravel",
  "version": "1.0.1",
  "description": "Reclaim your focus by making distracting websites less interesting.",
  "permissions": ["storage", "tabs", "scripting", "alarms"],
  "host_permissions": [
    "https://*.reddit.com/*",
    "https://*.youtube.com/*",
    "https://*.discord.com/*",
    "https://*.twitter.com/*",
    "https://*.x.com/*",
    "https://*.instagram.com/*",
    "https://*.tiktok.com/*",
    "https://*.facebook.com/*",
    "https://*.threads.net/*",
    "https://*.snapchat.com/*",
    "https://*.pinterest.com/*",
    "https://*.tumblr.com/*",
    "https://*.bsky.app/*",
    "https://*.twitch.tv/*",
    "https://*.imgur.com/*",
    "https://*.quora.com/*",
    "https://*.mastodon.social/*",
    "https://*.news.ycombinator.com/*"
  ],
  "optional_host_permissions": [
    "https://*/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "commands": {
    "toggle-grayscale": {
      "suggested_key": {
        "default": "Alt+Shift+G"
      },
      "description": "Toggle grayscale on/off"
    }
  }
}
